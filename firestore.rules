rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Rule for global templates
    match /templates/global {
      // Anyone can read (guests or signed-in users) so templates are instantly usable
      allow read: if true;

      // Only the verified admin can modify templates
      allow write: if request.auth != null && 
                     request.auth.token.email == "sovannetmeas.sm@gmail.com" && 
                     request.auth.token.email_verified == true;
    }
  }
}
